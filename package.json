{
  "name": "changdu-template-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:full": "node start-dev.js",
    "build": "vue-tsc --build && vite build",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "prepare": "husky",
    "commit": "cz",
    "lint:staged": "lint-staged",
    "server": "node server.js",
    "server:dev": "NODE_ENV=development node server.js",
    "server:prod": "NODE_ENV=production node server.js",
    "start": "pnpm run build && pnpm run server:prod"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@koa/cors": "^5.0.0",
    "@koa/router": "^14.0.0",
    "@volcengine/tos-sdk": "^2.7.5",
    "@vueuse/integrations": "^13.9.0",
    "axios": "^1.12.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^3.6.0",
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.2",
    "form-data": "^4.0.4",
    "http-proxy-middleware": "^3.0.5",
    "koa": "^3.0.1",
    "koa-body": "^6.0.1",
    "koa-bodyparser": "^4.4.1",
    "koa-cors": "^0.0.16",
    "koa-mount": "^4.2.0",
    "koa-router": "^14.0.0",
    "koa-socket-2": "^2.0.0",
    "koa-static": "^5.0.0",
    "koa2-connect": "^1.0.2",
    "naive-ui": "^2.43.0",
    "pinia": "^3.0.3",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "sortablejs": "^1.15.6",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1",
    "vuedraggable": "4.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.16.5",
    "@types/socket.io": "^3.0.2",
    "@types/sortablejs": "^1.15.8",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.21",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "~10.3.0",
    "husky": "^9.1.7",
    "jiti": "^2.4.2",
    "lint-staged": "^16.1.6",
    "postcss": "^8.5.6",
    "prettier": "3.6.2",
    "sass": "^1.92.1",
    "sharp": "^0.34.3",
    "tailwindcss": "^3.4.17",
    "terser": "^5.19.2",
    "typescript": "~5.8.0",
    "vite": "^5.4.10",
    "vite-plugin-vue-devtools": "^7.4.6",
    "vue-tsc": "^3.0.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "pnpm": {
    "overrides": {
      "nanoid": "5.1.5"
    }
  }
}
